{
  "name": "@eresearchqut/ddb-repository",
  "version": "1.13.5",
  "type": "module",
  "description": "A TypeScript library providing a generic repository pattern implementation for AWS DynamoDB, simplifying CRUD operations and common database interactions.",
  "main": "./dist/index.cjs",
  "types": "./dist/index.d.cts",
  "module": "./dist/index.mjs",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "scripts": {
    "build": "tsdown",
    "test": "NODE_OPTIONS=--experimental-vm-modules jest",
    "test:watch": "NODE_OPTIONS=--experimental-vm-modules jest --watch",
    "test:coverage": "NODE_OPTIONS=--experimental-vm-modules jest --coverage",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix"
  },
  "devDependencies": {
    "@aws-sdk/client-dynamodb": "^3.1050.0",
    "@aws-sdk/util-dynamodb": "^3.996.2",
    "@eslint/js": "^10.0.1",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/exec": "^7.1.0",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.8",
    "@semantic-release/npm": "^13.1.5",
    "@smithy/types": "^4.14.2",
    "@types/jest": "^30.0.0",
    "@types/lodash": "^4.17.24",
    "@types/node": "^25.9.1",
    "eslint": "^10.4.0",
    "eslint-plugin-jest": "^29.15.2",
    "jest": "^30.4.2",
    "semantic-release": "^25.0.3",
    "testcontainers": "^12.0.0",
    "ts-jest": "^29.4.10",
    "ts-node": "^10.9.2",
    "tsdown": "^0.22.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.4"
  },
  "peerDependencies": {
    "@aws-sdk/client-dynamodb": ">= 3.1050.0",
    "@aws-sdk/util-dynamodb": ">= 3.996.2",
    "lodash": ">= 4.18.1"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/eresearchqut/ddb-repository.git"
  }
}
